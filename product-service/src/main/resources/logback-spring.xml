<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Get the service name from Spring properties -->
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                %clr(...) adds colors for easier reading
                [%thread] shows which thread is active
                %-5level shows the log level (INFO, ERROR, etc.)
                %logger{36} shows the class name
                [%X{traceId:-},%X{spanId:-}] adds Micrometer Tracing (Sleuth replacement in SB 3.x)
            -->
            <pattern>
                %clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}
            </pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
