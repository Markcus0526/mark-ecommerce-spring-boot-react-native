apiVersion: apps/v1
kind: Deployment
metadata:
  annotations:
    kompose.cmd: D:\0_COMMON\kompose\kompose-windows-amd64.exe convert
    kompose.version: 1.38.0 (a8f5d1cbd)
  labels:
    io.kompose.service: favourite-service
  name: favourite-service
spec:
  replicas: 1
  selector:
    matchLabels:
      io.kompose.service: favourite-service
  template:
    metadata:
      annotations:
        kompose.cmd: D:\0_COMMON\kompose\kompose-windows-amd64.exe convert
        kompose.version: 1.38.0 (a8f5d1cbd)
      labels:
        io.kompose.service: favourite-service
    spec:
      # --- INIT CONTAINERS: These run and must finish before the main app starts ---
      initContainers:
        - name: wait-for-eureka
          image: busybox:1.28
          command: [ 'sh', '-c', "until nslookup service-discovery; do echo waiting for eureka; sleep 2; done" ]

        - name: wait-for-config-server
          image: busybox:1.28
          command: [ 'sh', '-c', "until nc -z cloud-config 9296; do echo waiting for config-server; sleep 2; done" ]

      # --- MAIN CONTAINER: Your Spring Boot Application ---
      containers:
        - env:
            - name: EUREKA_CLIENT_SERVICEURL_DEFAULTZONE
              value: http://service-discovery:8761/eureka/
            - name: EUREKA_INSTANCE_HOSTNAME
              value: favourite-service
            - name: MANAGEMENT_ZIPKIN_TRACING_ENDPOINT
              value: http://zipkin:9411/api/v2/spans
            - name: SPRING_CONFIG_IMPORT
              value: optional:configserver:http://cloud-config:9296
            - name: SPRING_PROFILES_ACTIVE
              value: dev
          image: mark-ecommerce-spring-boot-favourite-service:latest  # Ensure this matches your local image name
          imagePullPolicy: IfNotPresent
          name: favourite-service
          ports:
            - containerPort: 8800
              protocol: TCP
          resources:
            limits:
              memory: "512Mi"
              cpu: "500m"
            requests:
              memory: "256Mi"
              cpu: "250m"
      restartPolicy: Always
